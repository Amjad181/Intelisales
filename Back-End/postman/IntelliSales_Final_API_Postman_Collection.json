          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Backend is healthy', function () { pm.expect(body.data.status).to.eql('ok'); });"
                ]
              }
            }
          ]
