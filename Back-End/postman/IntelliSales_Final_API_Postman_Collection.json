{
  "info": {
    "_postman_id": "a8c7fc4b-9070-4c83-8326-8cd92d0e2d55",
    "name": "IntelliSales - Final API Handoff Collection",
    "description": "Final local API handoff collection for IntelliSales backend Modules 1-12. Import with IntelliSales_Local_Environment.json and run after seeding users, products, and price lists.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runStartedAt')) {",
          "  pm.environment.set('runStartedAt', Date.now().toString());",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const contentType = pm.response.headers.get('Content-Type') || '';",
          "if (contentType.includes('application/json')) {",
          "  const body = pm.response.json();",
          "  pm.test('Unified JSON response has success and message', function () {",
          "    pm.expect(body).to.have.property('success');",
          "    pm.expect(body).to.have.property('message');",
          "  });",
          "  if (pm.response.code >= 200 && pm.response.code < 300) {",
          "    pm.test('Success responses include data', function () {",
          "      pm.expect(body.success).to.eql(true);",
          "      pm.expect(body).to.have.property('data');",
          "    });",
          "  } else {",
          "    pm.test('Error responses use success false', function () {",
          "      pm.expect(body.success).to.eql(false);",
          "    });",
          "  }",
          "  pm.test('Sensitive internals are not exposed', function () {",
          "    const raw = pm.response.text();",
          "    pm.expect(raw).to.not.include('passwordHash');",
          "    pm.expect(raw).to.not.include('refreshTokenVersion');",
          "    pm.expect(raw).to.not.include('__v');",
          "  });",
          "}"
        ]
      }
    }
  ],
